# ══════════════════════════════════════════════════════════════
#  JugaHoyWeb Backend — Variables de entorno
#  Copiar a .env (desarrollo) o .env.production (producción).
#  NUNCA commitear archivos con valores reales.
# ══════════════════════════════════════════════════════════════

# ── Servidor ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development          # development | production

# ── Base de datos MySQL ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=jugahoyweb
DB_USER=root
DB_PASSWORD=
DB_SSL=false                  # true en producción con proveedores cloud (RDS, PlanetScale, etc.)
DB_POOL_MAX=5                 # Máximo de conexiones simultáneas (prod: 20)
DB_POOL_MIN=0                 # Mínimo de conexiones en pool     (prod: 5)

# ── JWT ───────────────────────────────────────────────────────
# Generar un secreto seguro: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_POR_SECRETO_SEGURO_DE_AL_MENOS_64_CARACTERES
JWT_EXPIRES_IN=7d

# ── Upload ────────────────────────────────────────────────────
UPLOAD_PATH=uploads/

# ── Frontend URL (para CORS) ──────────────────────────────────
# Desarrollo:  http://localhost:5173
# Producción:  https://jugahoy.com.ar,https://www.jugahoy.com.ar
FRONTEND_URL=http://localhost:5173

# ── Servir frontend desde Express (mismo servidor) ────────────
# true  → Express sirve ../frontend/dist además de la API
# false → Frontend en CDN separado (Vercel, Netlify, etc.)
SERVE_FRONTEND=false

# ── Nodemailer / SMTP ─────────────────────────────────────────
# Dejar vacío en dev → usa Ethereal (preview en consola)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=JugaHoy <noreply@jugahoy.com.ar>

# ── Google OAuth 2.0 ──────────────────────────────────────────
# Crear en: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# ── Meta / WhatsApp Business Cloud API ───────────────────────
# Obtener en: https://developers.facebook.com/apps/<APP_ID>/whatsapp-business/wa-dev-console
# META_PHONE_NUMBER_ID      → ID del número WhatsApp Business
# META_ACCESS_TOKEN         → System User Token permanente
# META_WEBHOOK_VERIFY_TOKEN → Token propio para verificar el webhook
#   URL webhook prod: https://api.jugahoy.com.ar/api/chatbot/webhook
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
META_BUSINESS_ID=
META_WEBHOOK_VERIFY_TOKEN=

# ── Chatbot ───────────────────────────────────────────────────
CHATBOT_COMPLEX_ID=1

# ── URLs del club (botones CTA del chatbot) ───────────────────
CLUB_WEB_URL=https://jugahoy.com.ar
CLUB_REGLAMENTO_URL=https://jugahoy.com.ar/reglamento
CLUB_PAGO_URL=https://jugahoy.com.ar/pagar

# ── Twilio SMS (alternativa al WhatsApp) ─────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_FROM=

# ── MercadoPago Checkout Pro ─────────────────────────────────
# El cobro va a la cuenta de CADA complejo (complexes.mercadopago_token).
# MP_ACCESS_TOKEN es el token de PLATAFORMA, usado solo como fallback cuando
# un complejo aún no configuró el suyo.
#   Test:  TEST-...        (sandbox)   |   Prod: APP_USR-...
#   Obtener en: https://www.mercadopago.com.ar/developers → Tus integraciones
MP_ACCESS_TOKEN=
MP_CURRENCY=ARS

# URLs públicas para back_urls (frontend) y notification_url (webhook backend)
# Dev:   http://localhost:5173  /  http://localhost:3001
# Prod:  https://jugahoy.com.ar /  https://api.jugahoy.com.ar
PUBLIC_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:3001

# ── Web Push (notificaciones push PWA) ───────────────────────
# Generar el par de claves una sola vez:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# La pública también debe exponerse al frontend (VITE_VAPID_PUBLIC_KEY).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:soporte@jugahoy.com.ar
